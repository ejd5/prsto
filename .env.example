# ELTON OS — Configuration
# Copiez ce fichier en .env et remplissez les valeurs

# ─── Authentication ─────────────────────────────────
# JWT Secret (OBLIGATOIRE en production)
# Utilisez une chaîne aléatoire d'au moins 32 caractères
# Générez avec: openssl rand -hex 32
JWT_SECRET="elton-os-dev-secret-change-in-production"

# ─── Encryption ─────────────────────────────────────
# ELTON_OS_SECRET_KEY (OBLIGATOIRE en production)
# Clé de chiffrement AES-256-GCM pour les API keys stockées en DB
# Doit faire au moins 32 caractères. Idéalement 64+.
# Générez avec: openssl rand -hex 32
# ELTON_OS_SECRET_KEY="votre-cle-de-chiffrement-32-caracteres-minimum"

# ─── Database ───────────────────────────────────────
# Base de données SQLite (locale)
DATABASE_URL="file:./dev.db"
# Pour PostgreSQL en production:
# DATABASE_URL="postgresql://user:password@host:5432/eltonos"

# ─── AI Provider (optionnel — ELTON OS fonctionne sans) ──
# L'API key se configure aussi via l'UI /parametres (chiffrée en DB)
# Laisser vide au premier lancement
# Providers supportés: openrouter (recommandé), deepseek
# AI_PROVIDER=openrouter
# AI_MODEL=openai/gpt-oss-120b:free

# ─── Firecrawl Safe Connector (optionnel) ────────────
# FIRECRAWL_API_KEY=fc-...
# FIRECRAWL_ENABLED=false
# FIRECRAWL_MAX_PAGES_PER_RUN=10
# FIRECRAWL_TIMEOUT_MS=30000

# ─── Safe Source Registry (limites des runs groupés) ──
# SAFE_SOURCES_MAX_PER_RUN=5
# SAFE_SOURCES_MAX_JOBS_PER_SOURCE=20
# SAFE_SOURCES_RUN_ENABLED=false
# SAFE_SOURCES_CRON_ENABLED=false

# ─── Firecrawl Garde-fous coût ──────────────────────
# FIRECRAWL_DAILY_MAX_REQUESTS=25
# FIRECRAWL_DAILY_MAX_JOBS_IMPORTED=100

# ─── Chrome Extension Import Assisté Pro (CORS) ─────
# Extension ID visible dans chrome://extensions
# ELTON_EXTENSION_ALLOWED_ORIGINS=chrome-extension://akkfmbjfjjklnlkmobadmgeogopakkkd

# ─── Next.js ────────────────────────────────────────
NEXT_PUBLIC_ELTON_DEMO_MODE=false
