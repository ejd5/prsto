# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Sessions navigateur ELTON OS (sensibles)
.elton/

# Base de données locale (SQLite)
prisma/dev.db
*.db
*.sqlite
*.sqlite3

# Tests E2E (artefacts)
/test-results
/playwright-report

# Exemple de variables d'environnement (commit autorisé)
!.env.example
