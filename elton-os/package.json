{
  "name": "elton-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "npx prisma db push --skip-generate && next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "prisma": {
      "seed": "npx tsx prisma/seed.ts"
    },
    "db:reset": "rm -f prisma/dev.db && npx prisma migrate dev && npm run db:seed",
    "db:studio": "npx prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:critical": "playwright test e2e/critical/",
    "test:e2e:critical:headed": "playwright test e2e/critical/ --headed",
    "test:e2e:report": "playwright show-report",
    "smoke:demo": "tsx scripts/smoke-demo-mode.ts",
    "jobs:semantic-backfill": "npx tsx scripts/backfill-semantic-scores.ts",
    "jobs:semantic-backfill:dry": "npx tsx scripts/backfill-semantic-scores.ts --dry",
    "prisma:refresh": "prisma generate",
    "dev:fresh": "prisma generate && next dev",
    "smoke:pipeline-api": "bash scripts/smoke-pipeline-api.sh",
    "smoke:firecrawl-safe": "tsx scripts/smoke-firecrawl-safe.ts",
    "seed:safe-sources": "tsx scripts/seed-safe-job-sources.ts",
    "auth:create-user": "tsx scripts/create-user.ts",
    "db:migrate-opportunity-to-job": "tsx scripts/migrate-opportunity-to-job.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.12.0",
    "next": "16.2.9",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "z-ai-web-dev-sdk": "^0.0.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
